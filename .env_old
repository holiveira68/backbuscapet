# ── Servidor ────────────────────────────────────
PORT=3001

# ── Banco de Dados MySQL ─────────────────────────
DB_HOST=localhost       # endereço do servidor MySQL
DB_USER=root            # usuário do banco
DB_PASS='aluno'  # senha do banco
DB_NAME=buscapet5        # nome do banco (criado pelo schema.sql)
DB_PORT=3306            # porta padrão do MySQL

# ── Autenticação JWT ─────────────────────────────
# IMPORTANTE: troque por uma string longa e aleatória em produção!
# Gere uma com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET='buscapet5'
JWT_EXPIRES=7d          # tempo de expiração do token (7 dias)
