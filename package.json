{
  "name": "buscapet-backend",
  "version": "4.0.0",
  "description": "Buscapet API — Node.js + Express + Prisma + MySQL",
  "main": "server.js",
  "scripts": {
    "start": "npx prisma db push && npx prisma db seed && node server.js",
    "dev": "nodemon server.js",
    "db:migrate": "npx prisma migrate deploy",
    "db:push": "npx prisma db push",
    "db:studio": "npx prisma studio",
    "db:generate": "npx prisma generate",
    "db:seed": "node prisma/seed.js"
    },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "jsonwebtoken": "^9.0.2",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.9.13"
  },
  "devDependencies": {
    "nodemon": "^3.1.0",
    "prisma": "^5.22.0"
  }
}
