# ═══════════════════════════════════════════════
# BUSCAPET — Variáveis de Ambiente (Prisma)
# ═══════════════════════════════════════════════
# 1. Copie este arquivo para backend/.env
#    cp config/.env.example .env
# 2. Preencha com seus dados reais
# 3. NUNCA suba o .env para o git
# ═══════════════════════════════════════════════

# ── Servidor ────────────────────────────────────
PORT=3001

# ── Banco de Dados MySQL (Prisma usa DATABASE_URL) ──
# Formato: mysql://USER:PASS@HOST:PORT/DATABASE
DATABASE_URL="mysql://root:aluno@localhost:3306/buscapet5"

# ── Autenticação JWT ─────────────────────────────
# Gere com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="buscapet5"
JWT_EXPIRES=7d

# ── Admin ─────────────────────────────────────────
ADMIN_KEY=buscapet-admin

# ── E-mail (opcional — necessário para recuperar senha) ──
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=seuemail@gmail.com
MAIL_PASS=sua-app-password-do-gmail
MAIL_FROM=Buscapet <noreply@buscapet.com>
